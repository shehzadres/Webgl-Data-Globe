{
  "name": "globe3d",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,glsl,css}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-spring/three": "^9.7.3",
    "@react-spring/web": "^9.7.5",
    "@react-three/drei": "^9.109.2",
    "@react-three/fiber": "^8.17.6",
    "gsap": "^3.12.5",
    "leva": "^0.9.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "three": "^0.166.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.166.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "prettier": "^3.3.3",
    "stats.js": "^0.17.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-glsl": "^1.3.0"
  },
  "description": "Production-quality WebGL-powered interactive 3D Earth data visualization",
  "keywords": [
    "globe",
    "webgl",
    "three.js",
    "react-three-fiber",
    "data-visualization",
    "glsl",
    "typescript"
  ],
  "homepage": "https://github.com/shehzadres/globe3d",
  "repository": {
    "type": "git",
    "url": "https://github.com/shehzadres/globe3d.git"
  },
